# =============================================================================
# nginx site config for Autonomous Trader
#
#   Public hostname : traderapp.dyndns.org
#   Upstream        : @APP_SERVER_IP@:8000 (the Windows app server's LAN IP)
#
# This file is generated by publish.bat. After scp'ing it to the nginx server
# at /etc/nginx/sites-available/traderapp.dyndns.org, do:
#
#   sudo ln -sf /etc/nginx/sites-available/traderapp.dyndns.org \
#               /etc/nginx/sites-enabled/traderapp.dyndns.org
#   sudo nginx -t
#   sudo systemctl reload nginx
#   sudo certbot --nginx -d traderapp.dyndns.org   # gets + installs SSL cert
#
# install_on_nginx_server.sh does all of this in one shot.
# =============================================================================

upstream traderapp_backend {
    server @APP_SERVER_IP@:8000 max_fails=3 fail_timeout=30s;
    keepalive 16;
}

# HTTP — serves ACME challenges, redirects everything else to HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name traderapp.dyndns.org;

    # Let's Encrypt http-01 challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — the actual site. certbot will fill in ssl_certificate paths.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name traderapp.dyndns.org;

    # ---- SSL ----
    # certbot will overwrite these on first run with the Let's Encrypt paths.
    ssl_certificate     /etc/letsencrypt/live/traderapp.dyndns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/traderapp.dyndns.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # ---- Security headers ----
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ---- Body size (Trade-journal CSV export can be large) ----
    client_max_body_size 16m;

    # ---- Proxy to the FastAPI app ----
    location / {
        proxy_pass http://traderapp_backend;

        # Pass real client info to FastAPI
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # WebSocket upgrades (chat + any future live streams)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # LLM calls can take 30-60s; outlook full-run takes ~5s but the
        # Optimize-iterate flow makes 5 sequential LLM calls = ~100s.
        proxy_connect_timeout 10s;
        proxy_send_timeout    120s;
        proxy_read_timeout    180s;

        # Don't buffer responses (streamed snapshots, server-sent events)
        proxy_buffering off;
    }

    # ---- Static assets — cache aggressively ----
    location /static/ {
        proxy_pass http://traderapp_backend;
        proxy_set_header Host $host;
        # The app already serves versioned URLs (?v=N), so we can cache hard.
        proxy_cache_valid 200 7d;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # ---- Health probe (no auth, no encryption needed for monitor) ----
    location = /metrics {
        proxy_pass http://traderapp_backend;
        # Optional: lock to local network only.
        # allow 192.168.1.0/24;
        # deny all;
    }
}
