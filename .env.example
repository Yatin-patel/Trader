# =============================================================================
# Bootstrap configuration only. All operational settings live in the database
# and are editable via the Settings UI at http://localhost:8000/settings
# =============================================================================

# --- SQL Server Express (bootstrap connection) ---
# ODBC Driver 17 or 18 for SQL Server must be installed locally.
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=TraderDB
DB_TRUSTED_CONNECTION=yes
# If using SQL auth instead of trusted connection, set these and turn the flag off:
# DB_TRUSTED_CONNECTION=no
# DB_USER=sa
# DB_PASSWORD=your_password

# --- API server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Encryption key for secrets at rest (32 url-safe base64 bytes) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, secrets will be stored in plaintext (development only).
SECRET_ENCRYPTION_KEY=
